{
  "name": "lockmeout",
  "version": "0.1.0",
  "private": true,
  "description": "Time-locked password vault",
  "main": "server.js",
  "scripts": {
    "build": "esbuild src/app.js --bundle --format=esm --outfile=public/app.js",
    "prestart": "npm run build",
    "start": "node server.js",
    "dev": "npm run build && node --watch server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "tlock-js": "^0.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
